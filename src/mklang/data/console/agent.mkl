# yaml-language-server: $schema=../../../../schema/mklang.schema.json
# agent.mkl — the console's brain (ADR 0015): one run per user turn.
#
# Flow: decide → {workspace scan/search/read/analyze | discover |
#                 prepare_run → do_run | clarify | author → save | reply → END}
#       (every action loops back to decide; the budget bounds the turn)
# Shows: the console's intelligence as an ordinary, auditable machine — swap it
# with `mklang console --agent your_brain.mkl` as long as the tool contract
# (list_machines / run_machine / ask_user, console-registered) is honored.
# Contract: the console sets `user_message` and `history`; observations
# accumulate under `observation`; the turn's answer lands in `reply`.
#
# Prompt assembly (reference interpreter): structure + execution → system;
# prompt (with {{…}}) → user. Put sticky policy in execution; turn data in prompt.

mklang: "0.3"
machine: console_agent
entry: decide
# Shared step budget for the whole turn: discover/run/clarify + author + up to
# two static check repairs (write_machine → check only) + reply. There is no
# separate language-level "repair budget" — headroom lives here. Authoring
# check-fail rate measured ~28% after one repair (docs/experiments/authoring-blind-spot.md).
budget: 24
default_tier: balanced
result: reply

hooks:
  - name: console_workspace_ready
    description: >
      Host guard: required project-analysis turns may reply only after a
      workspace observation and an evidence brief exist.

tools:
  - name: list_machines
    description: >
      The catalog of commissionable machines (console-registered).
      Input: {} — returns JSON rows with name, result, budget, context keys.
  - name: run_machine
    description: >
      Commission a machine and return its outcome as JSON.
      Input: {"request": '{"target": "...", "inputs": {...}}'} — the console
      brokers HITL escalations to the human and streams live events.
      Observation may include truncated: true / result_truncated: true —
      never invent the missing tail of a cut result.
  - name: ask_user
    description: >
      Ask the human one question and return the reply.
      Input: {"question": "..."}.
  - name: write_machine
    description: >
      Save an authored .mkl into the workspace (filename derived from its
      machine: field) and return the validation verdict.
      Input: {"source": "<the full .mkl document>"}.
  - name: list_workspace
    description: >
      Read-only listing of visible project files and directories. Input is a
      JSON request string {"path": "", "depth": 1}. Paths are relative to the
      configured workspace; hidden/build/vendor directories are excluded.
  - name: read_workspace_file
    description: >
      Read one visible UTF-8 project file without writing. Input is a JSON
      request string {"path": "README.md", "max_bytes": 120000}. The result
      reports truncation; never infer omitted content.
  - name: search_workspace
    description: >
      Search visible UTF-8 project files without shell access. Input is a JSON
      request string {"query": "...", "path": "", "max_results": 40}.

context:
  user_message: ""
  history: "" # prior turns, supplied by the console session
  observation: [] # tool observations of THIS turn (accumulated)
  today: "" # host fills ISO date when empty
  now: "" # host fills local ISO datetime when empty
  workspace_context: {} # host-provided deterministic snapshot of this folder
  workspace_brief: "" # compact evidence summary for multi-step analysis
  workspace_required: false # host classification for explicit project analysis

states:
  decide: # the ReAct "think" step
    structure: >
      One line starting with exactly one of WORKSPACE_SCAN, WORKSPACE_SEARCH,
      WORKSPACE_READ, WORKSPACE_ANALYZE, DISCOVER, RUN, CLARIFY, AUTHOR or
      REPLY, followed by the details: for RUN the machine name and the inputs
      to pass; for workspace actions the JSON request; for CLARIFY the question
      to ask the user; for AUTHOR the full requirements of the machine to
      create; for REPLY the substance of the answer.
    execution: |
      You are the mklang console agent: satisfy the user by commissioning
      machines (self-contained LLM state machines) and reporting honestly.
      You cannot call the web yourself — only host tools inside a commissioned
      machine can (especially tool: search). Never invent search results or
      answer live-web questions from training knowledge alone.
      Prefer existing stdlib/workspace machines over AUTHOR when one fits.
      When the user asks to analyze, inspect, review, understand, audit or
      summarize a project/folder, do not REPLY from memory: first choose
      WORKSPACE_SCAN, then search/read the relevant files, then
      WORKSPACE_ANALYZE. Read applicable AGENTS.md, CLAUDE.md or CONTRIBUTING.md
      before making project-wide claims. Report paths actually consulted and
      distinguish observed facts from inference. The workspace tools are
      read-only and their exclusions/truncation are authoritative.
      For wall-clock date/time questions, REPLY using the host today/now values
      in the user message — do not AUTHOR a machine only for the clock, and do
      not invent a time from training data.
      If a tool returned search unbound, say how to enable it (TAVILY_API_KEY or
      MKLANG_SEARCH_BACKEND). If an observation has truncated: true or
      result_truncated: true, report the cutoff and do not invent the missing
      part. No side effects in this generative state.
    prompt: |
      Today is {{today}}. Current local time is {{now}} (host clock).

      Workspace snapshot: {{workspace_context}}
      Workspace evidence brief: {{workspace_brief}}

      Conversation so far: {{history}}
      User request: {{user_message}}
      Observations this turn: {{observation}}

      Choose the single next action:
      - WORKSPACE_SCAN — list the project root or a relevant directory before
        analyzing a folder/project.
      - WORKSPACE_SEARCH — find symbols, files or project instructions after a
        scan; provide a JSON request with query/path/max_results.
      - WORKSPACE_READ — read a specific relevant file; provide a JSON request
        with path/max_bytes.
      - WORKSPACE_ANALYZE — synthesize the observed workspace evidence into a
        brief with file references, facts, inferences and coverage limits.
      - DISCOVER — list the available machines (only if you don't already know
        a suitable one from the observations).
      - RUN — commission a machine now: name it and spell out its inputs.
        For live web/news/current-events, AUTHOR or RUN a machine that uses
        the host tool `search`.
      - CLARIFY — ask the human one precise question you cannot answer yourself.
      - AUTHOR — no existing machine covers the request: spell out the machine
        to create (purpose, inputs, states, when it should escalate). If a
        previous authoring attempt failed validation, restate the requirements
        including what to fix.
      - REPLY — the request is satisfied (or answerable directly): state the
        substance of the final answer.
    tier: reasoning
    reason: true
    output: thought
    gates:
      - when: the output chooses DISCOVER
        then: ok
        to: discover
      - when: the output chooses RUN
        then: ok
        to: prepare_run
      - when: the output chooses CLARIFY
        then: ok
        to: clarify
      - when: the output chooses AUTHOR
        then: ok
        to: author
      - when: the output chooses REPLY
        then: ok
        to: reply
      - when: the output chooses WORKSPACE_SCAN
        then: ok
        to: prepare_workspace_scan
      - when: the output chooses WORKSPACE_SEARCH
        then: ok
        to: prepare_workspace_search
      - when: the output chooses WORKSPACE_READ
        then: ok
        to: prepare_workspace_read
      - when: the output chooses WORKSPACE_ANALYZE
        then: ok
        to: analyze_workspace
      - when: otherwise
        then: ok
        to: reply

  prepare_workspace_scan:
    structure: 'A JSON object {"path": ""} and nothing else.'
    execution: Output only the JSON object, without markdown or commentary.
    prompt: |
      Convert the workspace scan decision into JSON.
      Decision: {{thought}}
      Workspace snapshot: {{workspace_context}}
    tier: fast
    output: workspace_request
    gates: [{ when: otherwise, then: ok, to: workspace_scan }]

  workspace_scan:
    tool: list_workspace
    input: { request: "{{workspace_request}}" }
    output: observation
    accumulate: true
    gates: [{ when: otherwise, then: ok, to: decide }]

  prepare_workspace_search:
    structure: 'A JSON object {"query": "...", "path": "", "max_results": 40} and nothing else.'
    execution: Output only the JSON object, without markdown or commentary.
    prompt: |
      Convert the workspace search decision into JSON.
      Decision: {{thought}}
    tier: fast
    output: workspace_request
    gates: [{ when: otherwise, then: ok, to: workspace_search }]

  workspace_search:
    tool: search_workspace
    input: { request: "{{workspace_request}}" }
    output: observation
    accumulate: true
    gates: [{ when: otherwise, then: ok, to: decide }]

  prepare_workspace_read:
    structure: 'A JSON object {"path": "...", "max_bytes": 120000} and nothing else.'
    execution: Output only the JSON object, without markdown or commentary.
    prompt: |
      Convert the workspace read decision into JSON.
      Decision: {{thought}}
    tier: fast
    output: workspace_request
    gates: [{ when: otherwise, then: ok, to: workspace_read }]

  workspace_read:
    tool: read_workspace_file
    input: { request: "{{workspace_request}}" }
    output: observation
    accumulate: true
    gates: [{ when: otherwise, then: ok, to: decide }]

  analyze_workspace:
    structure: >
      A compact evidence brief for the current project analysis. Include facts
      with relative file paths, separate inferences, and list any uninspected
      or truncated areas.
    execution: |
      Use only workspace snapshot and tool observations. Never claim a file was
      read unless its content appears in the observations. Keep the brief below
      3000 words and preserve exact relative paths.
    prompt: |
      Analyze the workspace evidence collected so far.
      Workspace snapshot: {{workspace_context}}
      Observations: {{observation}}
      Previous brief: {{workspace_brief}}
      Produce an evidence-grounded brief with sections FACTS, INFERENCES and
      LIMITS. Do not invent missing files or implementation details.
    tier: reasoning
    output: workspace_brief
    gates: [{ when: otherwise, then: ok, to: decide }]

  workspace_guard:
    tool: list_workspace
    input: { request: '{"path": "", "depth": 1}' }
    output: observation
    accumulate: true
    gates: [{ when: otherwise, then: ok, to: analyze_workspace }]

  discover:
    tool: list_machines
    output: observation
    accumulate: true
    gates:
      - when: otherwise
        then: ok
        to: decide

  prepare_run: # thought → one JSON blob the run tool consumes verbatim
    structure: >
      A JSON object {"target": "<machine name>", "inputs": {<context key>:
      <value>, ...}} and nothing else. Values may be strings, numbers or lists.
    execution: |
      Output only the JSON object — no markdown fences, no commentary.
    prompt: |
      Turn this decision into the run request JSON:
      {{thought}}
    tier: fast
    output: run_request
    gates:
      - when: otherwise
        then: ok
        to: do_run

  do_run: # the ReAct "act" step
    tool: run_machine
    input:
      request: "{{run_request}}"
    output: observation
    accumulate: true
    gates:
      - when: otherwise
        then: ok
        to: decide

  clarify:
    tool: ask_user
    input:
      question: "{{thought}}"
    output: observation
    accumulate: true
    gates:
      - when: otherwise
        then: ok
        to: decide

  author: # write a new machine from the decided requirements
    structure: >
      A complete, valid .mkl document and nothing else — no fences, no prose
      around it.
    execution: |
      Emit only the .mkl source. Follow language 0.3 rules: never name a provider
      or model (tier only); never put side effects in generative prose — real I/O
      uses tool: states; time-sensitive machines declare today: "" and wall-clock
      ones now: ""; every multi-gate state ends with when: otherwise last.
    prompt: |
      Author the machine described here:
      {{thought}}

      Observations so far (fix any validation errors they report):
      {{observation}}

      Rules for a valid .mkl document:
      - Top-level keys: mklang: "0.3", machine (snake_case name), entry,
        budget (shortest entry→END path + 2), optional default_tier / result /
        context, states. Optional top-level tools: list of {name, description}.
      - A generative state has structure (output shape → system channel),
        execution (sticky policy → system), prompt (turn task + context
        interpolation → user), output (context key), gates. Optional: tier,
        reason, accumulate, sample: N, over, parse: list.
      - Host tools available in this console (use real `tool:` states for I/O):
        search (web — input query/max_results/days/topic, returns JSON results
        with optional published_date), calc (arithmetic expr), search_kb,
        send_reply. Declare them under top-level tools: and call with e.g.
        tool: search, input mapping the query, output notes (accumulate ok).
        NEVER put "search the web" only in a generative prompt — that fabricates
        results. For news/research: plan_query → tool search → check/finalize
        (see research_web / research_compress / news_search patterns).
      - For time-sensitive machines declare `today: ""` in context: — the host
        fills today's ISO date. For wall-clock time declare `now: ""` (host
        fills local ISO datetime). Prompts should say "Today is {{today}}" /
        "Current time is {{now}}" and forbid filling gaps with pre-training
        knowledge older than today.
      - Every gate is `when: <prose condition>` plus exactly one policy —
        `then: ok` / `repair: N` / `escalate: true` / `fail: true` — and
        `to: <state or END>` (fail has no to; escalate REQUIRES to:).
      - A state with more than one gate ends with `- when: otherwise` as the
        catch-all, last. Do not use `when: always`.
      - Declare a context default for every key the prompts read; `result`
        names a key some state outputs.
    tier: reasoning
    output: authored_source
    gates:
      - when: otherwise
        then: ok
        to: save

  save: # persist + validate; the observation carries the check verdict
    tool: write_machine
    input:
      source: "{{authored_source}}"
    output: observation
    accumulate: true
    gates:
      - when: otherwise
        then: ok
        to: decide

  reply:
    structure: >
      The final answer for the user: plain, complete, and honest about what was
      run and what it returned (or why nothing needed to run).
    execution: |
      Be honest: if search was unbound or empty, say so. If an observation has
      truncated / result_truncated, say the output was cut off and do not invent
      the rest. For wall-clock date/time, use the host today/now values from the
      user message. For other live facts, ground only in tool observations —
      not training knowledge older than today.
    prompt: |
      Today is {{today}}. Current local time is {{now}}.
      User request: {{user_message}}
      Your decision: {{thought}}
      Observations this turn: {{observation}}

      Write the final reply to the user.
    output: reply
    gates:
      - when: the required workspace analysis is complete
        hook: console_workspace_ready
        then: ok
        to: END
      - when: otherwise
        then: ok
        to: workspace_guard
