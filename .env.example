# Copy to .env and fill in the keys for the providers you use.
# .env is gitignored; NEVER commit real keys. Names match config/runtime.example.yaml.

DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
# GEMINI_API_KEY=
# LOCAL_API_KEY=      # usually unused for Ollama/vLLM

# Web search host tool (ADR 0016). Offline stub unless a backend is selected.
# If TAVILY_API_KEY is set, Tavily is auto-enabled (no MKLANG_SEARCH_BACKEND needed).
# Force offline: MKLANG_SEARCH_BACKEND=stub
# Demo without network: MKLANG_SEARCH_BACKEND=fake
# TAVILY_API_KEY=
# MKLANG_SEARCH_BACKEND=tavily
