# Copy to .env and fill in the keys for the providers you use.
# .env is gitignored; NEVER commit real keys. Names match config/runtime.example.yaml.

DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
# GEMINI_API_KEY=
# LOCAL_API_KEY=      # usually unused for Ollama/vLLM

# Host tool backends (ADR 0016 / 0020). Defaults are honest offline stubs.
# Web search: TAVILY_API_KEY alone auto-enables Tavily.
# Force offline: MKLANG_SEARCH_BACKEND=stub
# Demo without network: MKLANG_SEARCH_BACKEND=fake
# TAVILY_API_KEY=
# MKLANG_SEARCH_BACKEND=tavily
# KB showcase tool: MKLANG_KB_BACKEND=stub|fake
# Mail showcase tool: MKLANG_MAIL_BACKEND=stub|fake  (fake = in-memory outbox)
# Filesystem data tools (ADR 0024): live reads under MKLANG_FS_ROOT or the cwd.
# MKLANG_FS_ROOT=            # workspace root (default: current directory)
# MKLANG_FS_BACKEND=stub     # stub|local — stub forces offline (CI)
# MKLANG_FS_WRITE=1          # grant write_file on real disk (headless runs)
